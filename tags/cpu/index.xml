    <item>
      <title>手动切换CPU频率模式</title>
      <link>https://ponyofshadows.com/posts/linux/%E6%89%8B%E5%8A%A8%E5%88%87%E6%8D%A2cpu%E9%A2%91%E7%8E%87%E6%A8%A1%E5%BC%8F/</link>
      <pubDate>Sun, 10 Nov 2024 09:07:24 +0800</pubDate>
      <guid>https://ponyofshadows.com/posts/linux/%E6%89%8B%E5%8A%A8%E5%88%87%E6%8D%A2cpu%E9%A2%91%E7%8E%87%E6%A8%A1%E5%BC%8F/</guid>
      <description>&lt;p&gt;需要用到的包：&lt;code&gt;cpupower&lt;/code&gt;&lt;/p&gt;&#xA;&lt;p&gt;切换到性能模式：&lt;/p&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;&#34;&gt;&lt;code class=&#34;language-bash&#34; data-lang=&#34;bash&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;sudo cpupower frequency-set -g performance&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;切换到省电模式：&lt;/p&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;&#34;&gt;&lt;code class=&#34;language-bash&#34; data-lang=&#34;bash&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;sudo cpupower frequency-set -g powersave&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;查看当前频率信息：&lt;/p&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;&#34;&gt;&lt;code class=&#34;language-bash&#34; data-lang=&#34;bash&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;sudo cpupower frequency-info&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;</description>
    </item>
